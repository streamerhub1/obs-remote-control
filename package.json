{
  "name": "obs-remote-control",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check .",
    "dev": "turbo run dev",
    "dev:website": "pnpm --filter @obs-remote/website dev",
    "dev:desktop": "pnpm --filter @obs-remote/desktop dev",
    "build:website": "pnpm --filter @obs-remote/website build",
    "build:desktop": "pnpm --filter @obs-remote/desktop build",
    "dist:desktop:win": "pnpm --filter @obs-remote/desktop dist:win",
    "db:seed:demo": "pnpm --filter @obs-remote/database seed",
    "infra:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "dev:stack": "turbo run dev --filter @obs-remote/backend --filter @obs-remote/desktop"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}